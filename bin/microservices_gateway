#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path('../lib', __dir__))

require 'rackup'
require 'microservices_platform'

Rackup::Server.start(
  app: MicroservicesPlatform.gateway_app,
  server: 'puma',
  Host: '0.0.0.0',
  Port: Integer(ENV.fetch('PORT', '9595'))
)
